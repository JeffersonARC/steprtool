# =============================================================================
# steprtool configuration
# Copy this file to .env and edit values for your installation.
# =============================================================================

# -----------------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=8443
CERT_FILE=certs/cert.pem
KEY_FILE=certs/key.pem

# -----------------------------------------------------------------------------
# Step 100 (StepIR antenna controller)
# Set STEP100_PORT to MOCK (or leave blank) to run without hardware. Bytes
# will still be computed and shown in the UI; nothing is written to a serial
# port and the wait timer still runs.
# -----------------------------------------------------------------------------
STEP100_PORT=MOCK
STEP100_BAUD=4800
STEP100_BYTESIZE=8
STEP100_PARITY=N
STEP100_STOPBITS=1
STEP100_DTR=false
STEP100_RTS=false
STEP100_WAIT_SECONDS=10

# Element direction. Allowed values: normal, 180, bidirectional
# Maps to byte 7 of the command frame: 0x00 / 0x40 / 0x80.
STEP100_DIRECTION=normal

# -----------------------------------------------------------------------------
# DCU-2 (hy-gain rotator controller)
# Set DCU2_PORT to MOCK (or leave blank) to run without hardware.
# -----------------------------------------------------------------------------
DCU2_PORT=MOCK
DCU2_BAUD=4800
DCU2_BYTESIZE=8
DCU2_PARITY=N
DCU2_STOPBITS=1
DCU2_DTR=false
DCU2_RTS=false
DCU2_WAIT_SECONDS=60
