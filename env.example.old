# =============================================================================
# steprtool configuration
# Copy this file to .env and edit values for your installation.
# =============================================================================

# -----------------------------------------------------------------------------
# Web server
# -----------------------------------------------------------------------------
WEB_HOST=0.0.0.0
WEB_PORT=6300
CERT_FILE=certs/cert.pem
KEY_FILE=certs/key.pem

# -----------------------------------------------------------------------------
# SDA 100 (StepIR antenna controller)
# Set SDA100_PORT to MOCK (or leave blank) to run without hardware. Bytes
# will still be computed and shown in the UI; nothing is written to a serial
# port and the wait timer still runs.
# -----------------------------------------------------------------------------
SDA100_PORT=MOCK
SDA100_BAUD=4800
SDA100_BYTESIZE=8
SDA100_PARITY=N
SDA100_STOPBITS=1
SDA100_DTR=false
SDA100_RTS=false
SDA100_WAIT_SECONDS=10

# Initial element direction. Allowed values: normal, 180
# Maps to byte 7 of the command frame: 0x00 / 0x40 . This is the
# direction that's selected when the UI first loads; operators can change it
# at any time from the web interface.
SDA100_DIRECTION=normal

# -----------------------------------------------------------------------------
# DCU-2 (hy-gain rotator controller)
# Set DCU2_PORT to MOCK (or leave blank) to run without hardware.
# -----------------------------------------------------------------------------
DCU2_PORT=MOCK
DCU2_BAUD=4800
DCU2_BYTESIZE=8
DCU2_PARITY=N
DCU2_STOPBITS=1
DCU2_DTR=false
DCU2_RTS=false
DCU2_WAIT_SECONDS=60

# -----------------------------------------------------------------------------
# N1MM UDP listener
# steprtool listens for N1MM's RadioInfo XML broadcasts and auto-retunes the
# SDA 100 when N1MM's TXFreq changes by at least FREQ_CHANGE tens-of-Hz from
# the last value we sent.
#
# Sockets are opened with SO_REUSEADDR and SO_BROADCAST so multiple consumers
# (N1MM logger, steprtool, etc.) can share the same port (K3IT tip).
#
# UDP_PORTS: comma-separated list of ports to listen on.
# UDP_BIND_HOST: interface to bind. 127.0.0.1 if N1MM is on the same machine
#   (the usual case); 0.0.0.0 if you need to accept LAN broadcasts.
# FREQ_CHANGE: minimum delta from the last commanded frequency (in tens-of-Hz)
#   before we issue a retune. 100 = 1 kHz.
# -----------------------------------------------------------------------------
UDP_PORTS=12060,13063,13065
UDP_BIND_HOST=127.0.0.1
FREQ_CHANGE=100
